generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model WalletAccount {
  accountId     String        @id
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  ledgerEntries LedgerEntry[]

  @@map("wallet_account")
}

model Transaction {
  id            Int           @id @default(autoincrement())
  uuid          String        @unique @default(uuid()) // Auto-generated UUID
  createdAt     DateTime      @default(now())
  ledgerEntries LedgerEntry[]
  idempotency   Idempotency?

  @@map("transaction")
}

model Idempotency {
  key           String      @id // Client-provided transaction_id for idempotency
  transactionId Int         @unique
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@map("idempotency")
}

model LedgerEntry {
  id            Int           @id @default(autoincrement())
  transactionId Int
  transaction   Transaction   @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  accountId     String
  walletAccount WalletAccount @relation(fields: [accountId], references: [accountId], onDelete: Cascade)
  amount        Float         // Positive for credit (+), Negative for debit (-)
  timestamp     DateTime      @default(now())

  @@index([accountId])
  @@index([transactionId])
  @@map("ledger_entry")
}
